# Copy to `.env.local` and fill in. `NEXT_PUBLIC_*` vars are exposed to the browser (required for embeds).

# --- Search / launch ---
# Omit or leave unset while the site is private. Set to exactly `true` when you want Google indexing + permissive robots.txt.
# NEXT_PUBLIC_SITE_INDEXABLE=true

# --- Donorbox — /donate uses <dbox-widget> + widgets.js ---
# Campaign id from your embed (e.g. campaign="angel-paws-donation"). Defaults to angel-paws-donation if unset.
# NEXT_PUBLIC_DONORBOX_CAMPAIGN=angel-paws-donation

# --- Tally — /contact ---
# Form id = the part after https://tally.so/r/ in your form link.
NEXT_PUBLIC_TALLY_CONTACT_FORM_ID=
# Optional: separate "request a visit" form.
NEXT_PUBLIC_TALLY_VISIT_FORM_ID=

# --- Member portal — /members/portal (server-only; never expose to the browser) ---
# Shared password all active members use. Rotate in Vercel if it is ever shared too widely.
MEMBER_PORTAL_PASSWORD=
# Secret for signing the session cookie (e.g. `openssl rand -base64 32`). Min 16 characters.
MEMBER_PORTAL_COOKIE_SECRET=
# Optional: session length in seconds (default 604800 = 7 days; max 90 days).
# MEMBER_PORTAL_SESSION_MAX_AGE_SECONDS=604800

# --- Member portal admin — /admin/member-portal (not linked in the public nav; bookmark for operators) ---
# Single operator account (email + password). Values are server-only.
MEMBER_PORTAL_ADMIN_EMAIL=
MEMBER_PORTAL_ADMIN_PASSWORD=
# Optional: admin session length in seconds (default 1209600 = 14 days).
# MEMBER_PORTAL_ADMIN_SESSION_MAX_AGE_SECONDS=1209600

# --- Redis (Upstash) — persists member portal link list in production ---
# Any of these pairs work (first match wins). Use the https://… REST URL, not redis://.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Vercel Storage → KV / Redis often injects:
# KV_REST_API_URL=   + KV_REST_API_TOKEN=
# If the wizard used a custom prefix, STORAGE_URL + STORAGE_TOKEN when both are REST URL + token.
