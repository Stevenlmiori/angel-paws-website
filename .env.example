# Copy to `.env.local` and fill in. `NEXT_PUBLIC_*` vars are exposed to the browser (required for embeds).

# --- Donorbox — /donate uses <dbox-widget> + widgets.js ---
# Campaign id from your embed (e.g. campaign="angel-paws-donation"). Defaults to angel-paws-donation if unset.
# NEXT_PUBLIC_DONORBOX_CAMPAIGN=angel-paws-donation

# --- Tally — /contact ---
# Form id = the part after https://tally.so/r/ in your form link.
NEXT_PUBLIC_TALLY_CONTACT_FORM_ID=
# Optional: separate "request a visit" form.
NEXT_PUBLIC_TALLY_VISIT_FORM_ID=
